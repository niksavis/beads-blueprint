{
  "python.terminal.activateEnvironment": false,
  "editor.formatOnSave": false,
  "prettier.requireConfig": true,
  "terminal.integrated.defaultProfile.windows": "Git Bash (.venv)",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.profiles.windows": {
    "Git Bash (.venv)": {
      "source": "Git Bash",
      "args": ["--init-file", ".vscode/git-bash-init.sh"],
      "icon": "terminal-bash"
    },
    "Git Bash": {
      "source": "Git Bash",
      "icon": "terminal-bash"
    },
    "PowerShell (.venv)": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "& '.venv\\Scripts\\Activate.ps1'"]
    },
    "PowerShell": {
      "source": "PowerShell"
    }
  },
  "ruff.exclude": [".agents", ".beads", ".claude"],
  "markdownlint.configFile": ".markdownlint.json",
  "markdownlint.ignore": [
    ".markdownlintignore",
    "**/.markdownlintignore",
    ".agents/**",
    ".beads/**",
    ".claude/**",
    "**/.agents/**",
    "**/.beads/**",
    "**/.claude/**"
  ],
  "files.exclude": {
    ".agents": false,
    ".beads": false
  },
  "files.associations": {
    "*.markdownlint-cli2.jsonc": "jsonc"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": false
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": false
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "always",
      "source.organizeImports.ruff": "always"
    }
  }
}
